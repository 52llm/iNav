{
  "manifest_version": 3,
  "name": "iNav 收藏",
  "version": "0.1.0",
  "description": "一键收藏当前页到 iNav",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "收藏到 iNav"
  }
}
